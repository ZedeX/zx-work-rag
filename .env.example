# Volcengine Ark API (cloud mode)
# Get your API key from https://www.volcengine.com/
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CODING_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_EMBEDDING_MODEL=doubao-embedding-text-240915
ARK_LLM_MODEL=doubao-seed-2.0-pro

# Local embedding & chat provider
# Supports any OpenAI-compatible API server:
#   - LM Studio: http://localhost:1234/v1 (Windows/macOS)
#   - Ollama:    http://localhost:11434/v1 (Linux/macOS/Windows)
#   - vLLM:      http://localhost:8000/v1  (GPU servers)
#   - LocalAI:   http://localhost:8080/v1  (self-hosted)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_CHAT_MODEL=google/gemma-4-e2b
LM_STUDIO_EMBEDDING_MODEL=text-embedding-embeddinggemma-300m

# Embedding mode: "local" (LM Studio/Ollama) or "cloud" (Volcengine Ark)
EMBEDDING_MODE=local

# Source data directory - point this to your work files
# The scanner will recursively index all files under this path
SOURCE_DIR=

# Project data directories (defaults are usually fine)
PROJECT_DIR=.
DATA_DIR=./data
CONVERTED_DIR=./data/converted
CHROMA_DIR=./data/chroma_db
LOG_DIR=./data/logs
DB_PATH=./data/file_manifest.db

# Processing parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=64
BATCH_SIZE=100
